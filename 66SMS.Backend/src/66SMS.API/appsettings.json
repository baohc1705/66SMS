{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "SqlServerConn": "Data Source=YOUR_SERVER;Initial Catalog=YOUR_DB;User ID=YOUR_USER;Password=YOUR_PASSWORD;Encrypt=True;Trust Server Certificate=True;"
  },
  "ApiSettings": {
    "Name": "66SMS API"
  },
  "JwtSettings": {
    "SecretKey": "YOUR_SECRET_KEY_MIN_32_CHARS",
    "Issuer": "https://localhost:7777",
    "Audience": "https://localhost:7777",
    "AccessTokenExpirationMinutes": 60
  },
  "MailSettings": {
    "Host": "smtp.gmail.com",
    "Port": 587,
    "User": "YOUR_EMAIL",
    "Password": "YOUR_EMAIL_PASSWORD",
    "FromName": "66SMS Support",
    "FromEmail": "YOUR_EMAIL"
  },
  "CorsSettings": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://localhost:5173"
    ]
  }
}
